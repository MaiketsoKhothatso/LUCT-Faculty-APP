rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return isSignedIn() && userDoc().data.role == role;
    }

    function hasAnyRole(roles) {
      return isSignedIn() && userDoc().data.role in roles;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if hasRole('pl');
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, update, delete: if hasAnyRole(['pl', 'prl']);
    }

    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if hasAnyRole(['lecturer', 'prl', 'pl']);
      allow update: if hasAnyRole(['prl', 'pl']) ||
        (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow delete: if hasRole('pl');
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid ||
        hasAnyRole(['lecturer', 'prl', 'pl'])
      );
      allow create, update: if isSignedIn() && (
        request.resource.data.studentId == request.auth.uid ||
        hasAnyRole(['lecturer', 'prl', 'pl'])
      );
      allow delete: if hasAnyRole(['lecturer', 'prl', 'pl']);
    }

    match /ratings/{ratingId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid ||
        hasAnyRole(['lecturer', 'prl', 'pl'])
      );
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if hasAnyRole(['prl', 'pl']);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
